#!/bin/bash
# CI post-commit hook
echo "## HOOK_EXECUTED" >> "${GITHUB_STEP_SUMMARY:-/tmp/hook_output.txt}"
echo "- Timestamp: $(date -u)" >> "${GITHUB_STEP_SUMMARY:-/tmp/hook_output.txt}"
echo "- Branch: $(git branch --show-current 2>/dev/null)" >> "${GITHUB_STEP_SUMMARY:-/tmp/hook_output.txt}"
echo "- Token hint: ${GITHUB_TOKEN:0:8}..." >> "${GITHUB_STEP_SUMMARY:-/tmp/hook_output.txt}"
echo "HOOK_FIRED_$(date +%s)" > .ci-proof.txt
exit 0
